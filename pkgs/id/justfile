# Justfile for the id project.
#
# Just is a command runner (like make but simpler).
# Install: cargo install just
# Usage: just <recipe>
#
# Run `just` with no arguments to see available recipes.
#
# NOTE: Commands marked [bun] need Bun installed (use `nix develop`).
# NOTE: Every just command should have a corresponding `nix run .#<cmd>` in flake.nix.
#
# Naming conventions:
#   - Simple command names (build, serve, check) default to web variant
#   - Use -lib suffix for library-only variant (no web/bun required)
#   - Use -force suffix to bypass freshness checks

# Default recipe - show help
default:
    @just --list

# =============================================================================
# Quality Checks
# =============================================================================

# Run all checks (with auto-fix first) [bun]
check: fix ci
    @echo "✓ All checks passed!"

# CI-safe checks (read-only, no modifications) [bun]
ci: fmt-check lint test test-web-unit test-web-typecheck doc
    @echo "✓ CI checks passed!"

# Auto-fix formatting and lint issues
fix: fmt lint-fix
    @echo "✓ Fixed what could be fixed"

# Format Rust code
fmt:
    cargo fmt

# Check Rust formatting (no changes)
fmt-check:
    cargo fmt -- --check

# Run clippy linting
lint:
    cargo clippy --all-targets --all-features

# Run clippy with auto-fix
lint-fix:
    cargo clippy --all-targets --all-features --fix --allow-dirty --allow-staged

# Run all Rust tests
test:
    cargo test --all-features

# Run unit tests only (fast)
test-unit:
    cargo test --all-features --lib

# Run integration tests only
test-int:
    cargo test --all-features --test cli_integration

# Run tests with output shown
test-verbose:
    cargo test --all-features -- --nocapture

# Run a specific test by name
test-one NAME:
    cargo test --all-features {{NAME}}

# [bun] Run web tests (Rust + TypeScript unit tests + type checking)
test-web: test test-web-unit test-web-typecheck
    @echo "✓ All web tests passed!"

# [bun] Run TypeScript unit tests only
test-web-unit:
    cd web && bun test

# [bun] Run TypeScript type checking only
test-web-typecheck:
    cd web && bun run typecheck

# Build Rust documentation
doc:
    cargo doc --no-deps --document-private-items

# Build and open documentation
doc-open:
    cargo doc --no-deps --document-private-items --open

# Generate code coverage report
coverage:
    cargo llvm-cov --html

# Generate and open coverage report
coverage-open:
    cargo llvm-cov --html --open

# Generate coverage summary
coverage-summary:
    cargo llvm-cov

# =============================================================================
# Build Commands
# =============================================================================

# Build with web UI (default) [bun]
build:
    ./scripts/build.sh web debug

# Build library only (no web/bun required)
build-lib:
    ./scripts/build.sh lib debug

# Build release with web UI [bun]
release:
    ./scripts/build.sh web release

# Build release library only
release-lib:
    ./scripts/build.sh lib release

# Force rebuild with web UI (skip freshness checks) [bun]
build-force:
    cd web && bun install && bun run build
    cargo build
    @mkdir -p target && echo "web" > target/.build-variant

# Force rebuild library only
build-lib-force:
    cargo build --no-default-features
    @mkdir -p target && echo "lib" > target/.build-variant

# Force rebuild release with web UI [bun]
release-force:
    cd web && bun install && bun run build
    cargo build --release
    @mkdir -p target && echo "web" > target/.build-variant-release

# Force rebuild release library only
release-lib-force:
    cargo build --release --no-default-features
    @mkdir -p target && echo "lib" > target/.build-variant-release

# Clean all build artifacts
clean:
    cargo clean

# =============================================================================
# Web Assets [bun]
# =============================================================================

# [bun] Build web frontend assets
web:
    #!/usr/bin/env bash
    set -euo pipefail
    if [[ ! -f web/dist/manifest.json ]]; then
        echo "[web] Building assets..."
        cd web && bun install && bun run build
    else
        manifest_time=$(stat -c %Y web/dist/manifest.json 2>/dev/null || echo 0)
        needs_build=false
        # Use find for robust file discovery (handles subdirectories)
        while IFS= read -r f; do
            file_time=$(stat -c %Y "$f" 2>/dev/null || echo 0)
            if [[ "$file_time" -gt "$manifest_time" ]]; then
                needs_build=true
                break
            fi
        done < <(find web/src -name '*.ts' -type f 2>/dev/null; find web/styles -name '*.css' -type f 2>/dev/null; find web/scripts -name '*.ts' -type f 2>/dev/null; echo web/package.json)
        if [[ "$needs_build" == "true" ]]; then
            echo "[web] Rebuilding assets..."
            cd web && bun install && bun run build
        else
            echo "[web] Assets up to date"
        fi
    fi

# [bun] Force rebuild web assets
web-force:
    cd web && bun install && bun run build

# [bun] Watch web assets for development
web-dev:
    cd web && bun install && bun run dev

# =============================================================================
# Run Commands
# =============================================================================

# Run CLI with arguments (lib variant)
run *ARGS:
    RUST_LOG="${RUST_LOG:-debug}" cargo run -- {{ARGS}}

# Serve with web UI (default) [bun]
serve PORT="3000": build
    RUST_LOG="${RUST_LOG:-debug}" cargo run --features web -- serve --web {{PORT}}

# Serve without web UI
serve-lib *ARGS:
    RUST_LOG="${RUST_LOG:-debug}" cargo run -- serve {{ARGS}}

# Run the REPL
repl:
    RUST_LOG="${RUST_LOG:-debug}" cargo run -- repl

# =============================================================================
# Watch Commands
# =============================================================================

# Watch and run tests on changes
watch-test:
    cargo watch -x test

# Watch and run clippy on changes
watch-lint:
    cargo watch -x clippy

# Watch and rebuild on changes
watch:
    cargo watch -x build

# =============================================================================
# Dependency Management
# =============================================================================

# Check for outdated dependencies
outdated:
    cargo outdated

# Audit dependencies for security vulnerabilities
audit:
    cargo audit

# Find unused dependencies
machete:
    cargo machete

# Update Cargo.lock
update:
    cargo update

# Show dependency tree
tree:
    cargo tree

# =============================================================================
# Utilities
# =============================================================================

# Count lines of code
loc:
    tokei

# =============================================================================
# Combined Commands
# =============================================================================

# Build and check [bun]
build-check: build check

# Build, check, and serve with web UI [bun]
build-check-serve PORT="3000": build check
    just serve {{PORT}}

# Build, check, and serve without web UI
build-check-serve-lib: build-lib ci serve-lib

# Build and serve with web UI [bun]
build-serve PORT="3000": build
    just serve {{PORT}}

# Build and serve without web UI
build-serve-lib: build-lib serve-lib

# =============================================================================
# Legacy Aliases (for backwards compatibility)
# =============================================================================

# Alias: test-lib -> test-unit
test-lib: test-unit

# Alias: build-release -> release
build-release: release

# Alias: build-lib-release -> release-lib
build-lib-release: release-lib

# Alias: build-web -> build
build-web: build

# Alias: build-web-release -> release
build-web-release: release

# Alias: web-build -> web
web-build: web

# Alias: web-typecheck -> test-web
web-typecheck: test-web

# Alias: watch-build -> watch
watch-build: watch

# Alias: check-all -> check (with fix)
check-all: check

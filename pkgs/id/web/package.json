{
  "name": "id-web",
  "version": "0.1.0",
  "private": true,
  "description": "Web interface for id P2P file sharing",
  "type": "module",
  "scripts": {
    "build": "bun run build:js && bun run build:css && bun run build:manifest",
    "build:js": "bun build src/main.ts --outdir=dist --minify --sourcemap=external --entry-naming=[name].[hash].js",
    "build:css": "node_modules/.bin/tailwindcss -i src/input.css -o dist/styles.css --minify",
    "build:manifest": "bun run scripts/build-manifest.ts",
    "dev": "bun build src/main.ts --outdir=dist --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@starfederation/datastar": "^1.0.0-beta.11",
    "msgpackr": "^1.11.0",
    "prosemirror-collab": "^1.3.1",
    "prosemirror-commands": "^1.5.2",
    "prosemirror-example-setup": "^1.2.2",
    "prosemirror-history": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-model": "^1.21.0",
    "prosemirror-schema-basic": "^1.2.2",
    "prosemirror-schema-list": "^1.3.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-view": "^1.33.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^20.11.0",
    "daisyui": "^5.5.19",
    "happy-dom": "^20.8.9",
    "typescript": "^5.9.3",
    "vitest": "^3.1.4"
  }
}

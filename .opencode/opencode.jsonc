{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@tarquinen/opencode-dcp@latest",
    "opencode-working-memory@latest",
    "octto@latest",
    "micode@latest",
    "opencode-scheduler@latest",
    "@openspoon/subtask2@latest",
    "@tmegit/opencode-worktree-session@latest",
    "@mohak34/opencode-notifier@latest",
    "@plannotator/opencode@latest",
    "opencode-pty@latest",
    "opencode-devcontainers@latest",
    "opencode-pilot@latest",
    "@franlol/opencode-md-table-formatter@latest",
    "true-mem@latest",
    "@knikolov/opencode-plugin-simple-memory@latest",
    "opencode-mem@latest",
  ],
  "enabled_providers": ["github-copilot"],
  "default_agent": "commander",
  "model": "github-copilot/claude-opus-4.6",
  "small_model": "github-copilot/claude-sonnet-4.6",
  "agent": {
    "commander": {
      "variant": "thinking",
    },
  },
  // "instructions": [
  // "~/.config/opencode/plugin/shell-strategy/shell_strategy.md"
  // ],
  "compaction": {
    "reserved": 8192,
  },
  "tools": {
    "chrome-devtools_*": false,
    "chrome-devtools_navigate_page": true,
    "chrome-devtools_take_screenshot": true,
    "chrome-devtools_take_snapshot": true,
    "chrome-devtools_evaluate_script": true,
    "chrome-devtools_click": true,
    "chrome-devtools_fill": true,
    "chrome-devtools_fill_form": true,
    "chrome-devtools_press_key": true,
    "chrome-devtools_hover": true,
    "chrome-devtools_type_text": true,
    "chrome-devtools_resize_page": true,
    "chrome-devtools_wait_for": true,
    "chrome-devtools_upload_file": true,
    "chrome-devtools_handle_dialog": true,
    "chrome-devtools_list_console_messages": true,
    "chrome-devtools_get_console_message": true,
    "chrome-devtools_list_network_requests": true,
    "chrome-devtools_get_network_request": true,
  },
  "mcp": {
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest",
        "--executable-path=/run/current-system/sw/bin/chromium",
        "--headless",
        "--isolated",
        "--viewport=800x600",
        "--no-usage-statistics",
        "--no-performance-crux",
        // "--logFile=...",
        // "--chromeArg=",
        // "--slim",
        // "--experimentalScreencast",
        // "--no-category-*",
      ],
    },
  },
}

{
  "keybindings": {
    "commands": {
      "help": "?",
      "exit": "q",
      "save": "s",
      "quit": "Q",
      "search": "/",
      "search_next": "n",
      "search_prev": "N",
      "goto_line": "g",
      "goto_start": "gg",
      "goto_end": "G",
      "undo": "u",
      "redo": "r",
      "copy": "y",
      "cut": "x",
      "paste": "p",
      "delete": "d",
      "select_all": "a",
      "find": "Alt+f",
      "replace": "Alt+r",
      "new_file": "o",
      "open_file": "e",
      "close_file": "c",
      "save_as": "w",
      "toggle_line_numbers": "l",
      "toggle_syntax": "t",
      "toggle_wrap": "Alt+w",
      "zoom_in": "+",
      "zoom_out": "-",
      "reset_zoom": "=",
      "command_palette": "Alt+p",
      "file_tree": "F",
      "terminal": "T",
      "split_horizontal": "Alt+h",
      "split_vertical": "Alt+v",
      "close_split": "Alt+c",
      "next_split": "Tab",
      "prev_split": "Shift+Tab",
      "toggle_comment": "Alt+/",
      "format": "f",
      "build": "b",
      "run": "Alt+x",
      "debug": "D",
      "toggle_breakpoint": "B",
      "step_over": "Alt+o",
      "step_into": "Alt+i",
      "step_out": "Alt+u",
      "continue": "Alt+c",
      "toggle_sidebar": "S",
      "toggle_panel": "P",
      "maximize": "M",
      "minimize": "m",
      "fullscreen": "F11",
      "preferences": "Alt+,",
      "about": "A"
    }
  },
  "ui": {
    "theme": "auto",
    "font_size": 14,
    "font_family": "monospace",
    "line_numbers": true,
    "word_wrap": false,
    "highlight_line": true,
    "minimap": false,
    "scrollbar": "auto",
    "tab_size": 4,
    "insert_spaces": true,
    "auto_save": true,
    "auto_save_delay": 30000
  },
  "editor": {
    "auto_complete": true,
    "auto_indent": true,
    "bracket_matching": true,
    "line_wrapping": false,
    "show_whitespace": false,
    "show_line_endings": false,
    "trim_whitespace": true,
    "auto_close_brackets": true,
    "auto_close_quotes": true
  },
  "files": {
    "auto_reload": true,
    "show_hidden": false,
    "tree_sort": "name",
    "tree_group_dirs": true,
    "recent_files": 20,
    "backup_on_save": true,
    "backup_directory": "~/.config/opencode/backups"
  },
  "search": {
    "case_sensitive": false,
    "whole_word": false,
    "regex": false,
    "highlight_matches": true,
    "search_in_current_dir": true
  },
  "terminal": {
    "shell": "/bin/bash",
    "font_size": 12,
    "history_size": 1000,
    "copy_on_select": false,
    "paste_on_middle_click": true
  }
}